{
  "name": "@scout/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build --workspace @scout/types && npm run build --workspace @scout/schemas && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@fastify/cors": "^11.1.0",
    "@prisma/client": "^6.19.0",
    "@scout/schemas": "file:../../packages/schemas",
    "@scout/types": "file:../../packages/types",
    "ai": "^6.0.116",
    "fastify": "^5.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "5.7.3"
  }
}
